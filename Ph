  .toggle-label { font-size: 13px; color: var(--text); font-weight: 500; }
  .toggle-desc { font-size: 11px; color: var(--muted); font-family: 'DM Mono', monospace; margin-top: 2px; }

  .toggle {
    position: relative; width: 38px; height: 20px; flex-shrink: 0;
