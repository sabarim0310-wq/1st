  .enhance-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

  .enhance-btn .btn-shimmer {
    position: absolute; inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
